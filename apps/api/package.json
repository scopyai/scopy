{
  "name": "api",
  "private": true,
  "main": "./src/app/base.ts",
  "types": "./src/app/base.ts",
  "exports": {
    ".": {
      "types": "./src/app/base.ts",
      "default": "./src/app/base.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "@elysia/node": "^1.4.5",
    "@elysiajs/cors": "^1.4.1",
    "@octokit/webhooks": "^14.2.0",
    "better-auth": "^1.6.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "octokit": "^5.0.5",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
