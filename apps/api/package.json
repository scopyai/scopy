{
  "name": "api",
  "private": true,
  "type": "module",
  "main": "./src/app.ts",
  "types": "./src/app.ts",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "concurrently --kill-others --names api,worker \"pnpm dev:api\" \"pnpm worker\"",
    "dev:api": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "worker": "tsx watch src/worker.ts",
    "worker:start": "node dist/worker.js",
    "worker:migrate": "graphile-worker --schema-only",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "eval:docs": "tsx src/modules/docs/evals/run.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "db:backfill-review-usage": "tsx src/db/backfill-review-usage.ts"
  },
  "dependencies": {
    "@creem_io/webhook-types": "^1.0.0",
    "@elysia/node": "^1.4.5",
    "@elysiajs/cors": "^1.4.1",
    "@octokit/webhooks": "^14.2.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@workspace/billing": "workspace:*",
    "ai": "^6.0.193",
    "better-auth": "^1.6.5",
    "cheerio": "^1.2.0",
    "creem": "^1.5.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "graphile-worker": "^0.16.6",
    "octokit": "^5.0.5",
    "pg": "^8.20.0",
    "tools": "workspace:*",
    "tree-sitter": "^0.25.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "turndown": "^7.2.4",
    "undici": "^7.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@types/pg": "^8.20.0",
    "@types/turndown": "^5.0.6",
    "concurrently": "^10.0.0",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
